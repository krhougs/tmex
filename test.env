# tmex 测试环境共享行为配置（NODE_ENV=test）
# 由应用启动时经 @tmex/shared loadEnv() 自动加载（bun test 会自动设 NODE_ENV=test）。
#
# 刻意不写「按运行上下文变化的接线键」——DATABASE_URL / GATEWAY_PORT / FE_PORT /
# TMEX_BASE_URL / TMEX_GATEWAY_URL：
#   - 单元测试：preload 设 DATABASE_URL=:memory:
#   - e2e：playwright/run-e2e 注入动态端口、临时 db 与派生 URL
# 这些键不在本文件，loadEnv 的 override 才不会覆盖各入口注入的值。

NODE_ENV=test

# 测试用公开 master key
TMEX_MASTER_KEY=tGd9gPmdUkJrpRQK+db60sc+NkxymxgGqKrReDU4Kus=
TMEX_SITE_NAME=tmex

# 与 config.ts 默认值一致
TMEX_BELL_THROTTLE_SECONDS=6
TMEX_NOTIFICATION_THROTTLE_SECONDS=3
TMEX_TMUX_ALLOW_PASSTHROUGH=false
TMEX_TMUX_TERM_PROGRAM=ghostty
TMEX_TMUX_WINDOW_STYLE=fg=#d0d0d0,bg=#262626
TMEX_SSH_RECONNECT_MAX_RETRIES=2
TMEX_SSH_RECONNECT_DELAY_SECONDS=10
TMEX_DEFAULT_LANGUAGE=en_US

# ── 实测（live integration）凭证 ──
# 打真实 endpoint 的 *.integration.ts（test:live:* 脚本）所需。真实值不进仓库，
# 复制下列键到仓库根 test.env.local（已 gitignore）填写。缺失则报错退出，详见
# docs/testing/2026061302-live-integration-tests.md。
#
# LLM provider（test:live:llm）：
#   TEST_LLM_BASE_URL=https://your-endpoint        # 裸 host 会自动补 /v1
#   TEST_LLM_API_KEY=sk-...
#   TEST_LLM_MODEL=gpt-5.5
#   TEST_LLM_PROTOCOL=openai-responses                   # 可选，默认 openai-chat
# 搜索（test:live:search）：TEST_TAVILY_API_KEY / TEST_BRAVE_API_KEY 任选其一即可
# （配了哪个就测哪个，都配则都测）：
#   TEST_TAVILY_API_KEY=tvly-...
#   TEST_BRAVE_API_KEY=...
