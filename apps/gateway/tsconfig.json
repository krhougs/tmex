{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@tmex/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src/**/*"]
}
